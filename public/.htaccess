# ----------------------------------------------------------------------
# 🔧 SMRU Deployment: Ultimate Stability Config
# ----------------------------------------------------------------------

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 1. Force HTTPS and non-WWW (Canonical Domain smru.edu.in)
    # This prevents 'Link-Access' errors and SSL warnings
    RewriteCond %{HTTPS} off [OR]
    RewriteCond %{HTTP_HOST} ^www\. [NC]
    RewriteRule ^(.*)$ https://smru.edu.in/$1 [L,R=301]

    # 2. Maintenance Mode Switch (OFF)
    # RewriteCond %{REQUEST_URI} !/maintenance.html$ [NC]
    # RewriteCond %{REQUEST_URI} !/favicon.png [NC]
    # RewriteRule ^(.*)$ maintenance.html [R=302,L]

    # 3. If file or directory exists, serve it
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 4. SPA Fallback (All other links go to index.html)
    RewriteRule . index.html [L]
</IfModule>

# Security Lockdown
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# Caching Policy
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Block sensitive files
<FilesMatch "(\.env|\.pkg|package\.json|package-lock\.json|vite\.config\.js|tailwind\.config\.js)$">
    Order deny,allow
    Deny from all
</FilesMatch>

